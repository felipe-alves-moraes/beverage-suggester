{
  "name" : "forecast_mapping_invalid_key",
  "request" : {
    "urlPath" : "/data/2.5/weather",
    "method" : "GET",
    "queryParameters": {
      "q": {
        "matches": "^[a-zA-Z\\s,]+$"
      },
      "units": {
        "equalTo": "metric"
      }
    }
  },
  "response" : {
    "status" : 401,
    "jsonBody" : {"cod":401, "message": "Invalid API key. Please see http://openweathermap.org/faq#error401 for more info."}
  }
