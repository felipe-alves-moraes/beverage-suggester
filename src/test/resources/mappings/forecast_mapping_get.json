{
  "name" : "forecast_mapping",
  "request" : {
    "urlPath" : "/data/2.5/weather",
    "method" : "GET",
    "queryParameters": {
      "q": {
        "matches": "^[a-zA-Z\\s,]+$"
      },
      "appid": {
        "matches": "^[0-9a-zA-Z]+$"
      },
      "units": {
        "equalTo": "metric"
      }
    }
  },
  "response" : {
    "status" : 200,
    "bodyFileName" : "forecast_response.json",
    "headers" : {
      "Content-Type" : "application/json"
    }
  }
}